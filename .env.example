PORT=3000
NODE_ENV=development

# JWT Secret Key (Change this to a secure random string)
JWT_SECRET=super_secret_jwt_key_12345!

# PostgreSQL Connection Credentials
# Option 1: Using single Connection String (e.g. Neon, Render, Heroku)
# DATABASE_URL=postgresql://user:password@localhost:5432/gyanlok

# Option 2: Using individual variables
PGUSER=postgres
PGHOST=localhost
PGDATABASE=gyanlok
PGPASSWORD=postgres
PGPORT=5432
